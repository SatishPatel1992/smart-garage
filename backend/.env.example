# PostgreSQL connection string
DATABASE_URL="postgresql://admin:PASSWORD@localhost:5432/smart_garage?schema=public"

# JWT (for Express auth)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Optional: file upload path (local disk; later S3)
UPLOAD_DIR=./uploads

# Optional: allowed browser origins for the web app (comma-separated). If unset, any Origin is reflected (dev-friendly).
# CORS_ORIGINS=https://your-web.onrender.com,http://localhost:5173
