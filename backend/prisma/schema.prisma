// Smart Garage – Database Schema (Prisma + PostgreSQL)
// Scalable, normalized, and aligned with frontend domain models (FR-020–FR-082).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// AUTH & MULTI-TENANCY
// =============================================================================

/// Staff/users who log in (JWT). Optional role for future RBAC.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         String?  @default("staff") // e.g. admin, staff, mechanic
  organizationId String? @map("organization_id")
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

/// Refresh tokens for JWT rotation (revocable).
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

/// Optional: multi-tenant (e.g. multiple garages). Single tenant = one org.
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique
  address   String?
  phone     String?
  gstin     String?  // GST number (required in app when gstEnabled is true)
  settings  Json?    // { currency?, defaultTaxRates?, defaultGstRatePercent?, estimateValidityDays?, lowStockThreshold?, invoiceDefaultFormat?, logoUrl?, gstEnabled? }
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]
  customers Customer[]
  jobCards  JobCard[]
  mechanics Mechanic[]
  parts     Part[]
  vendors   Vendor[]
  reminders Reminder[]
  recurringContracts RecurringContract[]
  sequences Sequence[]
  purchaseOrders PurchaseOrder[]
  vehicleMakes VehicleMake[]

  @@map("organizations")
}

/// Per-year sequences for human-readable numbers (JC-2025-001, INV-2025-001).
model Sequence {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String   // e.g. "job_number", "estimate_number", "invoice_number", "credit_note_number"
  year           Int
  value          Int      @default(0)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, name, year])
  @@index([organizationId, name])
  @@map("sequences")
}

// =============================================================================
// CRM: CUSTOMERS & VEHICLES
// =============================================================================

model Customer {
  id             String    @id @default(uuid())
  organizationId String?    @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  email          String?
  address        String?
  gstin          String?
  deletedAt      DateTime? @map("deleted_at") // soft delete
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  vehicles       Vehicle[]
  jobCards       JobCard[]
  reminders      Reminder[]
  recurringContracts RecurringContract[]

  @@index([organizationId])
  @@index([phone])
  @@index([name])
  @@index([deletedAt])
  @@map("customers")
}

model Vehicle {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  registrationNo String  @map("registration_no")
  make           String
  model          String
  year           Int?
  vin            String?
  type           String?  // Sedan, SUV, etc.
  fuel           String?  // Petrol, Diesel
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  jobCards       JobCard[]
  reminders      Reminder[]
  recurringContracts RecurringContract[]

  @@unique([customerId, registrationNo])
  @@index([customerId])
  @@index([registrationNo])
  @@index([deletedAt])
  @@map("vehicles")
}

// =============================================================================
// VEHICLE MAKES & MODELS (Lookup Tables)
// =============================================================================

model VehicleMake {
  id             String        @id @default(uuid())
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  models         VehicleModel[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([name])
  @@map("vehicle_makes")
}

model VehicleModel {
  id             String        @id @default(uuid())
  vehicleMakeId String        @map("vehicle_make_id")
  vehicleMake   VehicleMake  @relation(fields: [vehicleMakeId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([vehicleMakeId, name])
  @@index([vehicleMakeId])
  @@index([name])
  @@map("vehicle_models")
}

// =============================================================================
// REMINDERS (CRM)
// =============================================================================

model Reminder {
  id             String      @id @default(uuid())
  organizationId String?     @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String      @map("customer_id")
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId      String?     @map("vehicle_id")
  vehicle        Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  type           String      // service_due | warranty_expiry | recall | other
  dueDate        DateTime    @map("due_date") @db.Date
  title          String
  description    String?
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([customerId])
  @@index([vehicleId])
  @@index([dueDate])
  @@index([organizationId])
  @@map("reminders")
}

// =============================================================================
// JOB CARDS (FR-020–FR-023)
// =============================================================================

model JobCard {
  id                  String    @id @default(uuid())
  organizationId      String?   @map("organization_id")
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobNumber           String    @unique @map("job_number") // e.g. JC-2025-001
  customerId          String    @map("customer_id")
  customer            Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleId           String    @map("vehicle_id")
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  insuranceCompanyId  String?   @map("insurance_company_id")
  insuranceCompany    InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id], onDelete: SetNull)
  complaints          String    @db.Text
  odometerReading     Int       @map("odometer_reading")
  stage               String    @default("pending") // pending | work_in_progress | delivered
  assignedMechanicId  String?   @map("assigned_mechanic_id")
  mechanic            Mechanic? @relation(fields: [assignedMechanicId], references: [id], onDelete: SetNull)
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  photos              JobPhoto[]
  mechanicTasks       MechanicTask[]
  estimates           Estimate[]
  invoices            Invoice[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([stage])
  @@index([createdAt])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([insuranceCompanyId])
  @@map("job_cards")
}

model JobPhoto {
  id        String   @id @default(uuid())
  jobCardId String   @map("job_card_id")
  jobCard   JobCard  @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  filePath  String   @map("file_path") // relative path; later S3 key
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobCardId])
  @@map("job_photos")
}

// =============================================================================
// MECHANICS & TASKS (FR-030–FR-032)
// =============================================================================

model Mechanic {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  jobCards       JobCard[]
  mechanicTasks  MechanicTask[]

  @@index([organizationId])
  @@map("mechanics")
}

model MechanicTask {
  id         String   @id @default(uuid())
  jobCardId  String   @map("job_card_id")
  jobCard    JobCard  @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  mechanicId String   @map("mechanic_id")
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  status     String   @default("assigned") // assigned | started | completed
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([jobCardId, mechanicId])
  @@index([jobCardId])
  @@index([mechanicId])
  @@map("mechanic_tasks")
}

// =============================================================================
// ESTIMATES (FR-040–FR-043)
// =============================================================================

model Estimate {
  id             String    @id @default(uuid())
  jobCardId      String    @map("job_card_id")
  jobCard        JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  estimateNumber String    @unique @map("estimate_number") // e.g. EST-JC-2025-001-ABC123
  status         String    @default("draft") // draft | sent | approved | rejected
  totalAmount    Decimal   @map("total_amount") @db.Decimal(12, 2)
  validUntil     DateTime? @map("valid_until") @db.Date
  sentAt         DateTime? @map("sent_at")
  approvedAt     DateTime? @map("approved_at")
  rejectedAt     DateTime? @map("rejected_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lines          EstimateLine[]
  revisions      EstimateRevision[]
  invoices       Invoice[]

  @@index([jobCardId])
  @@index([status])
  @@index([createdAt])
  @@map("estimates")
}

model EstimateLine {
  id                   String   @id @default(uuid())
  estimateId           String   @map("estimate_id")
  estimate             Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  sortOrder            Int      @default(0) @map("sort_order")
  description          String   @db.Text
  type                 String   // part | labour
  quantity             Decimal  @db.Decimal(10, 2)
  unitPrice            Decimal  @map("unit_price") @db.Decimal(12, 2)
  amount               Decimal  @db.Decimal(12, 2)
  insurancePayableMode String?  @map("insurance_payable_mode") // percent | rupees
  insurancePayableValue Decimal? @map("insurance_payable_value") @db.Decimal(10, 2)

  @@index([estimateId])
  @@map("estimate_lines")
}

model EstimateRevision {
  id          String   @id @default(uuid())
  estimateId  String   @map("estimate_id")
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  version     Int
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  note        String?  @db.Text
  linesSnapshot Json   @map("lines_snapshot") // JSON array of { description, type, quantity, unitPrice, amount }
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([estimateId])
  @@map("estimate_revisions")
}

// =============================================================================
// INVOICES & PAYMENTS (FR-060–FR-064, FR-070–FR-072)
// =============================================================================

model Invoice {
  id             String    @id @default(uuid())
  jobCardId      String    @map("job_card_id")
  jobCard        JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Restrict)
  estimateId     String?   @map("estimate_id")
  estimate       Estimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  billToType     String?   @default("customer") @map("bill_to_type") // customer | insurance
  invoiceNumber  String    @unique @map("invoice_number") // e.g. INV-2025-001
  format         String?   @default("tax") // proforma | tax
  partsAmount    Decimal   @map("parts_amount") @db.Decimal(12, 2)
  labourAmount   Decimal   @map("labour_amount") @db.Decimal(12, 2)
  taxAmount      Decimal   @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal   @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  pdfUrl         String?   @map("pdf_url")
  createdAt      DateTime  @default(now()) @map("created_at")
  lines          InvoiceLine[]
  payments       Payment[]
  creditNotes    CreditNote[]

  @@index([jobCardId])
  @@index([estimateId])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0) @map("sort_order")
  description String   @db.Text
  type        String   // part | labour
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model Payment {
  id             String   @id @default(uuid())
  invoiceId      String   @map("invoice_id")
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(12, 2)
  method         String   // upi | cash | card | bank_transfer
  status         String   @default("pending") // pending | completed | failed
  razorpayOrderId String? @map("razorpay_order_id")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@index([createdAt])
  @@map("payments")
}

model CreditNote {
  id              String   @id @default(uuid())
  invoiceId       String   @map("invoice_id")
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  creditNoteNumber String  @unique @map("credit_note_number") // e.g. CN-INV-2025-001-1
  amount          Decimal  @db.Decimal(12, 2)
  reason          String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("credit_notes")
}

// =============================================================================
// RECURRING / AMC
// =============================================================================

model RecurringContract {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String   @map("customer_id")
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId      String?  @map("vehicle_id")
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  description    String   @db.Text
  amount         Decimal  @db.Decimal(12, 2)
  frequency      String   // monthly | quarterly | yearly
  nextDueDate    DateTime @map("next_due_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([nextDueDate])
  @@index([organizationId])
  @@map("recurring_contracts")
}

// =============================================================================
// INVENTORY (FR-050–FR-053)
// =============================================================================

model Vendor {
  id            String   @id @default(uuid())
  organizationId String? @map("organization_id")
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name          String
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  address       String?
  gstin         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  parts         Part[]
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@map("vendors")
}

model Part {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String   // SKU
  name           String
  quantity       Decimal  @default(0) @db.Decimal(12, 2)
  minQuantity    Decimal  @map("min_quantity") @db.Decimal(12, 2) // reorder level
  unit           String   @default("piece")
  price          Decimal  @db.Decimal(12, 2) // selling price
  costPrice      Decimal? @map("cost_price") @db.Decimal(12, 2)
  vendorId       String?  @map("vendor_id")
  vendor         Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  stockMovements StockMovement[]
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([vendorId])
  @@index([code])
  @@index([name])
  @@map("parts")
}

model StockMovement {
  id             String   @id @default(uuid())
  partId         String   @map("part_id")
  part           Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  type           String   // purchase | issue_to_job | return
  quantity       Decimal  @db.Decimal(12, 2) // positive = in, negative = out
  referenceId    String?  @map("reference_id") // vendorId or jobCardId
  referenceLabel String?  @map("reference_label")
  unitCost       Decimal? @map("unit_cost") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([partId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model PurchaseOrder {
  id              String   @id @default(uuid())
  organizationId  String?  @map("organization_id")
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  poNumber        String   @unique @map("po_number")
  vendorId        String   @map("vendor_id")
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  status          String   @default("draft") // draft | sent | partially_received | received | cancelled
  expectedDate    DateTime? @map("expected_date") @db.Date
  notes           String?  @db.Text
  subtotalAmount  Decimal  @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount     Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  lines           PurchaseOrderLine[]

  @@index([organizationId])
  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id                String   @id @default(uuid())
  purchaseOrderId   String   @map("purchase_order_id")
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  partId            String   @map("part_id")
  part              Part     @relation(fields: [partId], references: [id], onDelete: Restrict)
  quantityOrdered   Decimal  @map("quantity_ordered") @db.Decimal(12, 2)
  quantityReceived  Decimal  @default(0) @map("quantity_received") @db.Decimal(12, 2)
  unitCost          Decimal  @map("unit_cost") @db.Decimal(12, 2)
  taxRatePercent    Decimal  @default(0) @map("tax_rate_percent") @db.Decimal(5, 2)
  lineAmount        Decimal  @map("line_amount") @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([partId])
  @@map("purchase_order_lines")
}

// =============================================================================
// LOOKUPS (ESTIMATE BUILDER / DROPDOWNS)
// =============================================================================

/// Insurance companies for estimate (insurance split).
model InsuranceCompany {
  id       String    @id @default(uuid())
  name     String
  jobCards JobCard[]

  @@map("insurance_companies")
}

/// Parts/labour catalogue for estimate line items (default price & tax). Distinct from inventory Part.
model ServiceItem {
  id                   String  @id @default(uuid())
  name                 String
  type                 String  // part | labour
  defaultUnitPrice     Decimal @map("default_unit_price") @db.Decimal(12, 2)
  defaultTaxRatePercent Decimal @map("default_tax_rate_percent") @db.Decimal(5, 2)
  isActive             Boolean @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([name])
  @@map("service_items")
}
